generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String       @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  icon        String       @default("target")
  sortOrder   Int          @default(0)
  active      Boolean      @default(true)
  services    Service[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Service {
  id          String        @id @default(cuid())
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  detailImageUrl String?
  durationMin Int
  priceCzk    Int
  capacity    Int           @default(1)
  active      Boolean       @default(true)
  sortOrder   Int           @default(0)
  reservations Reservation[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String
  verifiedEmail Boolean      @default(false)
  noShowCount  Int           @default(0)
  blocked      Boolean       @default(false)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Reservation {
  id          String   @id @default(cuid())
  publicCode  String   @unique
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  status      String   @default("confirmed") // confirmed, checked_in, cancelled, no_show
  note        String?
  qrToken     String   @unique
  checkedInAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startsAt, endsAt])
  @@index([customerId, status])
}

model BlockedTime {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
}

model OpeningHour {
  id        String  @id @default(cuid())
  weekday   Int
  opensAt   String
  closesAt  String
  active    Boolean @default(true)
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id            String   @id @default(cuid())
  reservationId String?
  to            String
  type          String   // confirmation, cancellation, reminder
  subject       String
  status        String   @default("queued")
  createdAt     DateTime @default(now())
}
